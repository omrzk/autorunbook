# === LLM provider (one of the two) ===========================
# Anthropic (recommended)
ANTHROPIC_API_KEY=
# ...or OpenRouter (used if ANTHROPIC_API_KEY is empty)
OPENROUTER_API_KEY=

# Model id. Defaults: claude-sonnet-5 (Anthropic) / anthropic/claude-sonnet-5 (OpenRouter)
AUTORUNBOOK_MODEL=

# Where the SQLite database lives (default: ./data/autorunbook.db)
AUTORUNBOOK_DB=

# Display name used as the default author/reviewer identity
AUTORUNBOOK_ACTOR=operator

# Set to 1 to try the app without any API key (returns a placeholder runbook)
AUTORUNBOOK_MOCK=0
